@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<form action="Account/Logout" method="post" id="logout-form">
    <AntiforgeryToken />
    <input type="hidden" name="ReturnUrl" value="account/login" />
</form>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await JS.InvokeVoidAsync("postearForm", "logout-form");// Llama a la función JavaScript para enviar el formulario
    }
}
