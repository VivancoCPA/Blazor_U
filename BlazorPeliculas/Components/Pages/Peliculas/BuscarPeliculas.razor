@page "/peliculas/buscar"
@inject IServicioPeliculas servicioPeliculas

<h3>Buscar Peliculas</h3>


<div class="row g-3 allign-items-center mb-3">
    <div class="col-sm-3">
        <input type="text" class="form-control" id="titulo" placeholder="Titulo Pelicula"
            @bind="titulo" @bind:event="oninput"
            @onkeypress="@((KeyboardEventArgs e) => TituloKeyPress(e))" autocomplete="off"
        />
    </div>
    <div class="col-sm-3">
        <select class="form-select" @bind="generoId">
            <option value="0">Seleccione un genero</option>
            @foreach (var item in generos)
            {
                <option value="@item.Id">@item.Nombre</option>
            }
        </select>
    </div>
    <div class="col-sm-6 d-flex">
        <div class="me-2">
            <BPCheckbox Label="Futuros Estrenos" @bind-Value="@futurosEstrenos"></BPCheckbox>
        </div>
        <div class="me-2">
            <BPCheckbox Label="En Cartelea" @bind-Value="@enCartelera"></BPCheckbox>
        </div>
        <div class="me-2">
            <BPCheckbox Label="Mas votadas" @bind-Value="@masVotadas"></BPCheckbox>
        </div>
    </div>
    <div class="col-12">
        <BPBoton OnClick="CargarNuevasPeliculas">Filtrar</BPBoton>
        <BPBoton OnClick="Limpiar" Variante="Variante.error">Limpiar</BPBoton>
    </div>
</div>

<ListadoPeliculas Peliculas="@Peliculas"></ListadoPeliculas>

@code {
    private string titulo = string.Empty;
    private int generoId = 0;
    private bool futurosEstrenos = false;
    private bool enCartelera = false;
    private bool masVotadas = false;
    private List<Genero> generos = new List<Genero>();
    private List<Pelicula>? Peliculas;

    protected override void OnInitialized()
    {
        generos = new List<Genero>
        {
            new Genero{ Id = 1, Nombre = "Acción"},
            new Genero{ Id = 2, Nombre = "Comedia"},
            new Genero{ Id = 3, Nombre = "Drama"},
            new Genero{ Id = 4, Nombre = "Terror"},
            new Genero{ Id = 5, Nombre = "Ciencia Ficción"}
        };

        Peliculas = servicioPeliculas.ObtenerPeliculas();
    }

    private void TituloKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            CargarNuevasPeliculas();
        }
    }

    private void CargarNuevasPeliculas()
    {
        Peliculas = servicioPeliculas.ObtenerPeliculas()
        .Where(p => p.Titulo.Contains(titulo, StringComparison.OrdinalIgnoreCase)).ToList();// Simulación de filtrado por título

        Console.WriteLine($"titulo: {titulo}");
        Console.WriteLine($"generoId: {generoId}");
        Console.WriteLine($"enCartelera: {enCartelera}");
        Console.WriteLine($"futurosEstrenos: {futurosEstrenos}");
        Console.WriteLine($"masVotadas: {masVotadas}");

    }

    private void Limpiar()
    {
        Peliculas = servicioPeliculas.ObtenerPeliculas();
        titulo = string.Empty;
        generoId = 0;
        futurosEstrenos = false;
        enCartelera = false;
        masVotadas = false;
        
    }
}