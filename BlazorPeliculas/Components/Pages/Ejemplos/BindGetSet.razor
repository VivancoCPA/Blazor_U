@page "/bind-get-set"
@rendermode InteractiveServer

<input @bind:get="Valor" @bind:set="SetAsync" @bind:event="oninput" />

<p>Valor: @Valor</p>

@code {
    private string Valor = string.Empty;

    private Task SetAsync(string texto)
    {
        Valor = texto.ToUpper();
        return Task.CompletedTask;
    }
    
}