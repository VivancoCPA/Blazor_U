
<FormularioEntidad Entidad="Actor"
                   FormularioPosteadoConExito="FormularioPosteadoConExito"
                   PosteoEnCurso="PosteoEnCurso"
                   OnValidSubmit="OnValidSubmit"
                   FormularioInvalido="FormularioInvalido">
    <!--Contenido del formulario-->
    <BPInputText Label="Nombre" @bind-Value="@Actor.Nombre"></BPInputText>
    <BPInputDate Label="Fecha de nacimiento" @bind-Value="@Actor.FechaNacimiento"></BPInputDate>
    <InputImg Label="Foto del Actor" ImagenSeleccionada="archivo => Actor.FotoArchivo = archivo"
              ImagenURL="@Actor.FotoURL"></InputImg>
</FormularioEntidad>

@code {
    [Parameter, EditorRequired] public Actor Actor { get; set; } = null!;
    [Parameter, EditorRequired] public bool FormularioPosteadoConExito { get; set; } = false;
    [Parameter, EditorRequired] public bool PosteoEnCurso { get; set; } = false;
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public bool FormularioInvalido { get; set; } = true;
    
}
